' 貼り付け先: F_特定5講座 のコードビハインド（フォームモジュール）に追記
'
' =============================================================
' 登録日によるサブフォームの絞り込み（コンボ参照方式）
'
' 動き:
'   ・フォームを開くと「今日」の登録日のデータだけを2つのサブフォームに表示
'   ・ヘッダーのドロップダウン（データがある登録日の一覧・新しい順）で
'     別日付に切替
'
' 仕組み:
'   絞り込みはサブフォームのクエリ側で行う（VBA は日付の初期値設定と
'   Requery だけ）。登録日は Date（日付のみ）に統一済みであることが前提
'   （時刻付きが残っていると = 比較でヒットしない。先に 一括修正_時刻除去 を実行）
'
' ★★★ 客先での準備 ★★★
'   1. F_特定5講座 のヘッダーにコンボボックスを1つ追加
'      （ウィザードが出たらキャンセル）
'   2. コンボボックスのプロパティを設定:
'        名前:         cbo対象日
'        書式:         日付 (S)
'        入力チェック: いいえ（一覧に無い日付も入力できるように）
'      ※値集合ソースはコードが自動設定するので空欄でよい
'   3. 一覧用サブフォームのレコードソースのクエリをデザインビューで開き、
'      [登録日] の抽出条件に以下を設定:
'        [Forms]![F_特定5講座]![cbo対象日]
'      ※チェック状況用のクエリには設定しない（2026-07-24 修正）。
'        チェック状況はリンク親/子フィールド（No）で絞られており、
'        チェックレコードの登録日は「チェック入力日」なので、受注の登録日と
'        一致せず既存チェックが表示されなくなる（No・受注番号等が空になる）
'   4. コンボボックスの「更新後処理」イベントに [イベント プロシージャ] を選択
'   5. フォームの「読み込み時」イベントに [イベント プロシージャ] を選択
'      （既に Form_Load がある場合は、その末尾に本コードの Form_Load の
'        中身を移して1つにまとめる）
'   6. 下の定数3つを実環境に合わせて修正
' =============================================================

' ★サブフォームコントロールの名前（フォーム名ではなく、メインフォーム上の
'   サブフォームコントロールの「名前」プロパティを確認して合わせる）
'   ※チェック状況側は日付で絞らないため再読込の対象外（2026-07-24 修正）
Private Const SUB_LIST As String = "F_SUB_特定5講座"

' ★ドロップダウンの日付一覧を作る元。
'   複数テーブルを結合したクエリを指定すると、双方に「登録日」がある場合に
'   「複数のテーブルを参照しました」エラーになるため、テーブルを直接指定する
Private Const DATE_SOURCE As String = "T_WORCS"

Private Sub Form_Load()
    'ドロップダウンに「データがある登録日」を新しい順で一覧表示
    Me!cbo対象日.RowSource = _
        "SELECT DISTINCT [登録日] FROM [" & DATE_SOURCE & "] " & _
        "ORDER BY [登録日] DESC"

    '初期表示は今日
    Me!cbo対象日.Value = Date
    RequerySubForms
End Sub

Private Sub cbo対象日_AfterUpdate()
    RequerySubForms
End Sub

'一覧サブフォームを再読込（絞り込みはクエリ側で行われる）
Private Sub RequerySubForms()
    On Error GoTo ErrHandler

    Me(SUB_LIST).Form.Requery
    Exit Sub

ErrHandler:
    MsgBox "サブフォームの再読込に失敗しました。" & vbCrLf & _
        "定数のサブフォームコントロール名を確認してください。" & vbCrLf & _
        "エラー内容: " & Err.Number & ": " & Err.Description, vbExclamation
End Sub
